# --- e-ship ---
# mcp-hub.config.json usa ${ESHIP_API_KEY} e ${ESHIP_API_BASE_URL}.
# Upstreams remotos: preferir "streamableHttp": { "url", "headers" } (hub liga em processo;
# contorna GET SSE 400 dos hosts e-ship). Entrada "command"/"npx mcp-remote" continua suportada.
# Modo HTTP: no primeiro POST (initialize) cabeçalhos, por exemplo:
#   X-Eship-Api-Key + X-Eship-Api-Base-Url (ou X-Api-Key + X-Api-Base-Url)
#   X-Eship-Api-Key-WMS + X-Eship-Api-Key-TAR: WMS e TAR em simultâneo (cada upstream usa a chave certa)
#   API-WMS / APIKEY-TAR: chave no valor do cabeçalho — envia sempre a base no mesmo pedido:
#   X-Eship-Api-Base-Url ou X-Api-Base-Url (ou _meta.eshipApiBaseUrl / apiBaseUrl).
#   A base tem de ser URL http:// ou https:// (ambos aceites).
# Modo stdio: define no mcp.json → "env" da entrada do hub (ou export antes de node).
# ESHIP_API_KEY=
# ESHIP_API_KEY_WMS=
# ESHIP_API_KEY_TAR=
# ESHIP_API_BASE_URL=https://fulle.eship.com.br/v3

# Modo URL (Streamable HTTP): http | stdio
MCP_HUB_TRANSPORT=http
# Porta interna do processo (e do mapeamento host, se MCP_PUBLIC_PORT não for usado)
MCP_HUB_HTTP_PORT=3343
# Porta publicada no host (opcional; no docker-compose mapeia host:container)
MCP_PUBLIC_PORT=3343
# 0.0.0.0 = qualquer IP acede à porta (rede/firewall deve permitir)
MCP_HUB_HTTP_HOST=0.0.0.0
MCP_HUB_HTTP_PATH=/mcp
# Com proxy reverso, lista de Host permitidos (separados por vírgula)
# MCP_HUB_ALLOWED_HOSTS=api.exemplo.com,localhost
# Atrás de nginx/HTTPS: para req.protocol e OAuth usarem https, define:
# MCP_HUB_TRUST_PROXY=1
# OAuth / PRM (Cursor): origem pública — evita mismatch http vs https
# MCP_HUB_OAUTH_PUBLIC_ORIGIN=https://central.mcp.eship.com.br
# Só o campo "resource" do PRM (opcional; senão usa origem + MCP_HUB_HTTP_PATH)
# MCP_HUB_OAUTH_RESOURCE_URL=https://central.mcp.eship.com.br/mcp
# Em host não-local, se o pedido for visto como http, o PRM usa https (defeito). Desligar: MCP_HUB_OAUTH_COERCE_HTTPS=0
# Token Bearer fictício devolvido pelo OAuth de conveniência (Cursor); opcional
# MCP_HUB_OAUTH_STUB_ACCESS_TOKEN=

# --- Admin web (/hub-admin): utilizadores + vários API tokens por utilizador + MCPs por token (URL/headers/env ou chave do catálogo + connection) ---
#
# Modo A — palavra-passe fixa (legado):
# MCP_HUB_ADMIN_PASSWORD=
# Opcional: segredo HMAC para cookie de sessão admin (senão reutiliza a palavra-passe)
# MCP_HUB_ADMIN_SECRET=
#
# Modo B — LDAP (MCP_HUB_LDAP_URL + MCP_HUB_ADMIN_SECRET). Utilizador e palavra-passe vêm sempre do formulário de login.
# O utilizador «admin» (minúsculas) é reservado: inicia sessão com MCP_HUB_ADMIN_PASSWORD (conta local), sem LDAP.
# Obrigatório com LDAP: MCP_HUB_ADMIN_SECRET (não uses a palavra-passe do utilizador LDAP como segredo de sessão).
# Para usar «admin», define também MCP_HUB_ADMIN_PASSWORD.
#
# B1 — LDAP simples (sem conta de serviço no .env): URL + BASE DN com DC= → bind como utilizador@dominio inferido (ex.: OU=x,DC=eship,DC=local → user@eship.local).
# MCP_HUB_LDAP_URL=ldap://10.77.89.247:389
# MCP_HUB_LDAP_BASE_DN=OU=Usuarios,DC=eship,DC=local
# Opcional: modelo explícito em vez da inferência (tem de incluir {{username}}):
# MCP_HUB_LDAP_USER_DN_TEMPLATE={{username}}@outro.dominio.pt
# MCP_HUB_LDAP_TIMEOUT_MS=8000
# ldaps com certificado não confiável (só em laboratório): MCP_HUB_LDAP_TLS_INSECURE=1
#
# B2 — LDAP com conta de serviço (opcional): só se as TRÊS variáveis abaixo estiverem definidas (senão usa-se o modo B1 directo).
# Erro «conta de serviço» / bindServiço = MCP_HUB_LDAP_BIND_* falhou no AD, não o utilizador do formulário.
# MCP_HUB_LDAP_BIND_DN=CN=ldapauth,OU=Usuarios,DC=eship,DC=local
# MCP_HUB_LDAP_BIND_PASSWORD=
# MCP_HUB_LDAP_USER_SEARCH_BASE=OU=Usuarios,DC=eship,DC=local
# MCP_HUB_LDAP_USER_FILTER=(&(objectCategory=person)(sAMAccountName={{username}}))
# MCP_HUB_LDAP_SEARCH_SCOPE=sub
# --- Persistência: ficheiro OU MongoDB (sem ficheiros .tmp) ---
# Sem MCP_HUB_MONGODB_URI: grava em JSON (um único write por alteração).
# Docker (USER node ~ UID 1000): volume em /app/data tem de pertencer a esse UID ou dar escrita, senão EACCES.
# MCP_HUB_USERS_FILE=/app/data/hub-users.json
# MCP_HUB_MCP_REGISTRY_FILE=/app/data/hub-mcp-registry.json
#
# Com MongoDB: utilizadores + registo na mesma coleção (dois documentos por _id).
# MCP_HUB_MONGODB_URI=mongodb://user:pass@host:27017
# MCP_HUB_MONGODB_DB=mcp_hub
# MCP_HUB_MONGODB_COLLECTION=hub_state
